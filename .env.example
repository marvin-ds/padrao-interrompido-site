# ==========================================================
# VARIÁVEIS DE AMBIENTE DO FUNIL EBOOK → QUIZ → AGENTES
# ==========================================================
# Este arquivo é apenas um modelo.
# NÃO coloque credenciais reais aqui.
# Configure os valores reais no painel do Netlify:
# Site configuration → Environment variables
#
# Arquivo real local, se necessário: .env
# O arquivo .env deve estar no .gitignore e não deve ser commitado.
# ==========================================================


# ==========================================================
# RESEND
# Usado para envio transacional do ebook gratuito.
# ==========================================================

RESEND_API_KEY=coloque_sua_api_key_do_resend_aqui
RESEND_FROM=Sua Marca <contato@seudominio.com.br>


# ==========================================================
# BREVO
# Usado para criar ou atualizar contatos capturados na página /ebook.
# ==========================================================

BREVO_API_KEY=coloque_sua_api_key_do_brevo_aqui
BREVO_LIST_ID_EBOOK=1
BREVO_LIST_ID_QUIZ_INTERESSE=2
BREVO_LIST_ID_CLIENTES_QUIZ=3
BREVO_SENDER_EMAIL=contato@seudominio.com.br
BREVO_SENDER_NAME=Sua Marca


# ==========================================================
# ZOHO CRM — PAUSADO NA FASE INICIAL
# Mantido apenas como referência histórica/técnica.
# A implementação atual usa Brevo como CRM simples inicial.
# ==========================================================

ZOHO_CLIENT_ID=coloque_seu_client_id_do_zoho_aqui
ZOHO_CLIENT_SECRET=coloque_seu_client_secret_do_zoho_aqui
ZOHO_REFRESH_TOKEN=coloque_seu_refresh_token_do_zoho_aqui

# Exemplo para contas globais:
# https://accounts.zoho.com
#
# Ajuste conforme o data center da conta Zoho, se necessário.
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# Exemplo para API global:
# https://www.zohoapis.com
#
# Ajuste conforme o data center da conta Zoho, se necessário.
ZOHO_API_DOMAIN=https://www.zohoapis.com


# ==========================================================
# EBOOK
# Link público do PDF ou material gratuito.
# Pode apontar para /docs/ebook.pdf ou para outro local público.
# ==========================================================

EBOOK_URL=https://seudominio.com.br/docs/ebook.pdf


# ==========================================================
# WHATSAPP — AGENTE ATENDENTE
# Número do WhatsApp do agente atendente.
# Usar apenas números, com código do país e DDD.
# Exemplo: 5513997615872
# ==========================================================

WHATSAPP_ATENDENTE=5513997615872


# ==========================================================
# QUIZ PAGO R$17
# Página para lead vindo do ebook:
# /quiz-mpi
#
# Página para público frio vindo de anúncio:
# /quiz
# ==========================================================

QUIZ_EBOOK_URL=https://seudominio.com.br/quiz-mpi/
QUIZ_FRIO_URL=https://seudominio.com.br/quiz/


# ==========================================================
# EDUZZ
# Opcional: incluir links de checkout se forem usados nas functions
# ou em futuras automações.
# Não usar se os links estiverem apenas nas páginas HTML.
# ==========================================================

EDUZZ_CHECKOUT_QUIZ_EBOOK=https://checkout.eduzz.com/SEU-CHECKOUT?utm_source=ebook&utm_medium=quiz_mpi&utm_campaign=quiz_17
EDUZZ_CHECKOUT_QUIZ_FRIO=https://checkout.eduzz.com/SEU-CHECKOUT?utm_source=meta&utm_medium=quiz_frio&utm_campaign=quiz_17


# ==========================================================
# AMBIENTE
# Usado para diferenciar desenvolvimento, teste e produção.
# ==========================================================

NODE_ENV=development
